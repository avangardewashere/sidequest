# Authentication secret used to sign and verify session tokens.
AUTH_SECRET=your-strong-random-secret-here

# MongoDB connection string used by the app's data layer.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# Public app URL used by auth callbacks and absolute links.
NEXTAUTH_URL=http://localhost:3000

# Optional NextAuth secret for compatibility with NextAuth conventions.
NEXTAUTH_SECRET=your-nextauth-secret-here
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/sidequest
AUTH_SECRET=replace-with-long-random-secret
